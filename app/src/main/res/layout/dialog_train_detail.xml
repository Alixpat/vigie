<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Position estimee -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/dialogPositionIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDCCD"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/dialogPosition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <!-- Barre de progression du trajet -->
    <ProgressBar
        android:id="@+id/dialogProgressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginBottom="16dp"
        android:max="100"
        android:progress="0" />

    <!-- Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_detail_section"
        android:padding="12dp">

        <!-- Depart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Depart"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/dialogDeparture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Arrivee -->
        <LinearLayout
            android:id="@+id/dialogArrivalRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Arrivee"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/dialogArrival"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Destination -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Destination"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/dialogDestination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Voie -->
        <LinearLayout
            android:id="@+id/dialogPlatformRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Voie"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/dialogPlatform"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Statut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Statut"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/dialogStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
